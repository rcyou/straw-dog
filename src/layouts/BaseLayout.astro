---
import '../styles/global.css'
const { pageTitle, metaDescription, } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
  </head>
  
  <body class="font-sans  min-h-screen flex flex-col antialiased bg-stone-100">
    <main id="main-content" role="main" class="relative grow-1 flex flex-col items-center justify-center px-6">
      <slot /> 
    </main>

    <footer role="contentinfo" class="flex p-6 flex-col items-center gap-2 sm:flex-row sm:justify-between text-base text-gray-500">
        <p>A Ryan Young Production.</p>
        <p>&copy; {new Date().getFullYear()}. All rights reserved.</p>
    </footer>

  </body>
</html>